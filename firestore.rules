rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — users can only read/write their own
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Playbook progress — scoped by user ID as document key
    match /playbookProgress/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // All other collections use a userId field on the document
    match /truthReports/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /offers/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /chatSessions/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /generatedContent/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /funnels/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /integrations/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /analyticsEvents/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /skills/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /prospect_memory/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /workspaces/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /engine_users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Rep profiles — reps can read their own profile; only bankDetails can be updated by the rep
    match /reps/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bankDetails']);
    }

    // Rep leads — reps can fully manage their own leads
    match /repLeads/{docId} {
      allow create: if request.auth != null && request.resource.data.repId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.repId == request.auth.uid;
    }

    // Rep commissions — reps can read their own; writes only via Admin SDK
    match /repCommissions/{docId} {
      allow read: if request.auth != null && resource.data.repId == request.auth.uid;
      allow write: if false;
    }

    match /deliverables/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if (request.auth != null && resource.data.userId == request.auth.uid)
                  || resource.data.get('isPublic', false) == true;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ── Rep Training Collections ──────────────────────────

    match /repTrainingSessions/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /repDrillSessions/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /repTrainingStats/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /repCallSessions/{docId} {
      allow create: if request.auth != null && request.resource.data.repId == request.auth.uid;
      allow read, update: if request.auth != null && resource.data.repId == request.auth.uid;
      allow delete: if false;
    }

    // Rep emails — reps can read their own logs; writes via Admin SDK only
    match /repEmails/{docId} {
      allow read: if request.auth != null && resource.data.repId == request.auth.uid;
      allow write: if false;
    }

    // Rep email replies — reps can read replies for their leads; writes via Admin SDK (webhook)
    match /repEmailReplies/{docId} {
      allow read: if request.auth != null && resource.data.repId == request.auth.uid;
      allow write: if false;
    }

    // ── Screening / Booking Collections ──────────────────

    // Slots are publicly readable so the booking page can show them
    match /screeningSlots/{slotId} {
      allow read: if true;
      allow write: if false; // admin SDK only
    }

    // Tokens are fully server-side; no client reads
    match /bookingTokens/{token} {
      allow read, write: if false; // admin SDK only
    }

    // Applicants — admin hiring pipeline, no client access
    match /applicants/{applicantId} {
      allow read, write: if false; // admin SDK only
    }

    // Trial task submissions — public write (one per email), admin SDK read
    match /trial_submissions/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // ── Client Portal Collections ──────────────────────────

    // Client profiles — clients read their own; writes via Admin SDK only
    match /clients/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Client deliverables — clients read their own; writes via Admin SDK only
    match /clientDeliverables/{docId} {
      allow read: if request.auth != null && resource.data.clientId == request.auth.uid;
      allow write: if false;
    }

    // Client feedback — clients create and read their own; updates/deletes via Admin SDK
    match /clientFeedback/{docId} {
      allow create: if request.auth != null && request.resource.data.clientId == request.auth.uid;
      allow read: if request.auth != null && resource.data.clientId == request.auth.uid;
      allow update, delete: if false;
    }

    // Client invoices — clients read their own; writes via Admin SDK only
    match /clientInvoices/{docId} {
      allow read: if request.auth != null && resource.data.clientId == request.auth.uid;
      allow write: if false;
    }

    // ── Settings ──────────────────────────

    // Announcement bar + other settings — any authenticated user can read; writes via Admin SDK
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
